---

import { getCollection } from 'astro:content';
import ContentListItem from '../components/ContentListItem.astro';
import Layout from '../layouts/Layout.astro';
import { isPublished, sortByDateDesc } from '../utils/content';

const posts = (await getCollection('blog', isPublished)).sort(sortByDateDesc);
---

<Layout title="Blog | Soumyo Dey">
  <main class="space-y-12 pt-24">
    <section class="reveal border-b border-[var(--color-border)] pb-12">
      <p class="section-eyebrow">Field notes</p>
      <h1 class="section-title mt-4">Stories from the build log</h1>
      <p class="section-description mt-4 max-w-2xl">
        Reflections on AI, product decisions, and the small stories that shape how we build.
      </p>
    </section>

    <div class="space-y-0">
      {
        posts.map((post, index) => (
          <ContentListItem
            href={`/blog/${post.id}`}
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            heroImage={post.data.heroImage}
            showDivider={index < posts.length - 1}
            animate
          />
        ))
      }
    </div>
  </main>
</Layout>