---

import { getCollection } from 'astro:content';
import ContentBentoGrid from '../../components/ContentBentoGrid.astro';
import Layout from '../../layouts/Layout.astro';
import { isPublished, toBentoItem } from '../../utils/content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', isPublished);
  const allProjects = await getCollection('projects', isPublished);

  const allContent = [...allPosts, ...allProjects];

  const uniqueTags = [...new Set(allContent.flatMap((item) => item.data.tags).filter(Boolean))];

  return uniqueTags.map((tag) => {
    const filteredContent = allContent.filter((item) => item.data.tags?.includes(tag));
    return {
      params: { tag },
      props: { items: filteredContent },
    };
  });
}

const { tag } = Astro.params;
const { items } = Astro.props;
---

<Layout title={`Posts tagged with ${tag}`}>
  <main class="space-y-12 pt-24">
    <section class="reveal border-b border-[var(--color-border)] pb-12">
      <p class="section-eyebrow">Tagged</p>
      <h1 class="section-title mt-4">#{tag}</h1>
      <p class="section-description mt-4">
        {items.length} {items.length === 1 ? 'item' : 'items'} tagged with this topic.
      </p>
    </section>

    <ContentBentoGrid animate items={items.map(toBentoItem)} />
  </main>
</Layout>