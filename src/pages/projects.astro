---



import { getCollection } from 'astro:content';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import Tags from '../components/Tags.astro';
import Layout from '../layouts/Layout.astro';
import { isPublished, sortByDateDesc } from '../utils/content';

const projects = (await getCollection('projects', isPublished)).sort(sortByDateDesc);
---

<Layout title="Work | Soumyo Dey">
  <main class="space-y-12">
    <!-- Header Section -->
    <section class="gsap-fade-up">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--color-text-muted)]">Build log</p>
      <h1 class="mt-4 text-4xl font-semibold text-[var(--color-text)] sm:text-5xl">Selected Work</h1>
      <p class="mt-4 max-w-2xl text-lg text-[var(--color-text-secondary)]">
        Experiments, shipping stories, and products that bend AI, strategy, and delightful UI into something useful.
      </p>
    </section>

    <!-- Projects Grid -->
    <div class="grid gap-8 md:grid-cols-2" data-animate-stagger>
      {
        projects.map((project) => (
          <article
            class="group relative flex flex-col rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-[var(--color-primary)]/30"
            data-animate-item
          >
            {project.data.heroImage && (
              <div class="relative mb-6 overflow-hidden rounded-xl">
                <ResponsiveImage
                  src={project.data.heroImage}
                  alt={project.data.title}
                  class="h-48 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                  sizes="(min-width: 768px) 50vw, 100vw"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-surface)]/60 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
              </div>
            )}

            <div class="flex flex-col flex-grow">
              <p class="text-xs font-medium uppercase tracking-[0.2em] text-[var(--color-text-muted)]">
                {project.data.date?.toLocaleDateString?.('en-US', { year: 'numeric', month: 'short' }) ?? 'Project'}
              </p>
              <h2 class="mt-2 text-xl font-semibold text-[var(--color-text)] transition-colors group-hover:text-[var(--color-primary)]">
                {project.data.title}
              </h2>
              <p class="mt-3 flex-grow text-[var(--color-text-secondary)] leading-relaxed">
                {project.data.description}
              </p>

              {project.data.tags && (
                <div class="mt-4">
                  <Tags tags={project.data.tags} />
                </div>
              )}

              <div class="mt-6 flex flex-wrap items-center gap-3 pt-4 border-t border-[var(--color-border)]/50">
                {project.data.github && (
                  <a
                    href={project.data.github}
                    class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] px-4 py-2 text-sm font-medium text-[var(--color-text-secondary)] transition-all hover:border-[var(--color-primary)]/50 hover:text-[var(--color-primary)]"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                    </svg>
                    Code
                  </a>
                )}
                {project.data.demo && (
                  <a
                    href={project.data.demo}
                    class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] px-4 py-2 text-sm font-medium text-[var(--color-text-secondary)] transition-all hover:border-[var(--color-primary)]/50 hover:text-[var(--color-primary)]"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    Demo
                  </a>
                )}
                <a
                  href={`/projects/${project.id}`}
                  class="ml-auto inline-flex items-center gap-1 text-sm font-medium text-[var(--color-primary)] transition-all hover:gap-2"
                  data-astro-prefetch
                >
                  View Details
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </main>
</Layout>
