---

import { getCollection } from 'astro:content';
import ContentCardStacked from '../components/ContentCardStacked.astro';
import Layout from '../layouts/Layout.astro';
import { isPublished, sortByDateDesc, toStackedProjectProps } from '../utils/content';

const projects = (await getCollection('projects', isPublished)).sort(sortByDateDesc);
---

<Layout title="Work | Soumyo Dey">
  <main class="space-y-12">
    <section class="gsap-fade-up">
      <p class="section-eyebrow">Build log</p>
      <h1 class="section-title mt-4">Selected Work</h1>
      <p class="section-description mt-4 max-w-2xl text-lg">
        Experiments, shipping stories, and products that bend AI, strategy, and delightful UI into something useful.
      </p>
    </section>

    <div class="grid gap-8 md:grid-cols-2" data-animate-stagger>
      {
        projects.map((project) => (
          <ContentCardStacked {...toStackedProjectProps(project)} animate />
        ))
      }
    </div>
  </main>
</Layout>