---
import Layout from '../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import { getCollection } from 'astro:content';
import avatar from '../images/avatar.jpg';

// Get latest blog posts
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

// Get projects if available
const allProjects = await getCollection('projects').catch(() => []);
const featuredProjects = allProjects.slice(0, 3);
---

<Layout title="Soumyo Dey">
  <!-- Hero Section -->
  <section class="relative -mx-4 -mt-24 min-h-screen overflow-hidden px-4 pt-24 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8">
    <!-- Hero background glow -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div
        class="absolute left-1/2 top-1/4 h-[600px] w-[600px] -translate-x-1/2 rounded-full opacity-40 blur-[100px]"
        style="background: radial-gradient(circle, rgba(139, 92, 246, 0.2) 0%, transparent 70%);"
      ></div>
      <div
        class="absolute bottom-0 right-0 h-[400px] w-[400px] rounded-full opacity-30 blur-[80px]"
        style="background: radial-gradient(circle, rgba(251, 113, 133, 0.15) 0%, transparent 70%);"
      ></div>
    </div>

    <div class="relative flex min-h-[calc(100vh-6rem)] flex-col items-center justify-center py-20">
      <!-- Eyebrow -->
      <div class="gsap-fade-up mb-8">
        <span class="inline-flex items-center gap-3 text-xs font-semibold uppercase tracking-[0.25em] text-[var(--color-text-muted)]">
          <span class="h-px w-8 bg-[var(--color-border-dark)]"></span>
          Tech · AI · Product · Stories
          <span class="h-px w-8 bg-[var(--color-border-dark)]"></span>
        </span>
      </div>

      <!-- Avatar with glow ring -->
      <div class="gsap-fade-up relative mb-10">
        <div class="absolute -inset-4 rounded-full bg-gradient-to-r from-[var(--color-accent)] via-[var(--color-coral)] to-[var(--color-accent)] opacity-20 blur-2xl"></div>
        <div class="relative h-32 w-32 overflow-hidden rounded-full border-2 border-[var(--color-border)] shadow-lg">
          <Picture
            src={avatar}
            widths={[128, 256]}
            sizes="128px"
            formats={['avif', 'webp', 'jpeg']}
            alt="Soumyo Dey"
            loading="eager"
            fetchpriority="high"
            class="h-full w-full object-cover"
          />
        </div>
      </div>

      <!-- Hero title -->
      <div class="mb-6 text-center">
        <h1
          id="hero-title"
          class="display-heading text-[var(--text-hero)] font-normal tracking-tight text-[var(--color-text)]"
          style="font-size: clamp(3rem, 8vw + 1rem, 7rem); line-height: 1;"
        >
          <span class="gsap-fade-up inline-block">Soumyo</span>
          <span class="gsap-fade-up inline-block">Dey</span>
        </h1>
      </div>

      <!-- Tagline -->
      <p
        class="gsap-fade-up mx-auto mb-12 max-w-xl text-center text-lg leading-relaxed text-[var(--color-text-secondary)] sm:text-xl"
      >
        Building products at the intersection of technology, data, and human insight.
        <span class="text-[var(--color-accent)]">20+ years</span> of stories along the way.
      </p>

      <!-- CTAs -->
      <div class="gsap-fade-up flex flex-col gap-4 sm:flex-row">
        <a
          href="/projects"
          class="btn btn-primary"
          data-astro-prefetch
        >
          View my work
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
        <a
          href="/blog"
          class="btn btn-secondary"
          data-astro-prefetch
        >
          Read my writing
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="gsap-fade-up absolute bottom-8 left-1/2 -translate-x-1/2">
        <div class="flex flex-col items-center gap-2 text-[var(--color-text-muted)]">
          <span class="text-xs uppercase tracking-widest">Scroll</span>
          <div class="h-8 w-px animate-pulse bg-gradient-to-b from-[var(--color-muted-dark)] to-transparent"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Preview Section -->
  <section class="section-spacing">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center lg:gap-16">
      <!-- Text content -->
      <div class="reveal">
        <div class="section-header">
          <p class="section-eyebrow">About</p>
          <h2 class="section-title">Building at the edge of what's possible</h2>
        </div>
        <div class="space-y-4 text-[var(--color-text-secondary)]">
          <p>
            I've spent two decades building products that sit at the intersection of technology, data, and human insight.
            From early-stage startups to scaled platforms, I've learned that the best products emerge from deep
            understanding—of users, systems, and the messy reality between them.
          </p>
          <p>
            Currently, I'm exploring how AI is reshaping the way we work, create, and make decisions.
            I write about product intuition, engineering systems, and signals from the AI landscape.
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/about"
            class="group inline-flex items-center gap-2 text-sm font-medium uppercase tracking-wider text-[var(--color-accent)] transition-colors hover:text-[var(--color-accent-glow)]"
            data-astro-prefetch
          >
            Learn more about me
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Stats/highlights card -->
      <div class="reveal">
        <div class="card-gradient p-8">
          <div class="grid gap-8 sm:grid-cols-2">
            <div>
              <div class="mb-2 text-3xl font-semibold text-[var(--color-text)]">20+</div>
              <div class="text-sm text-[var(--color-text-muted)]">Years building products</div>
            </div>
            <div>
              <div class="mb-2 text-3xl font-semibold text-[var(--color-text)]">AI/ML</div>
              <div class="text-sm text-[var(--color-text-muted)]">Data & Intelligence focus</div>
            </div>
            <div>
              <div class="mb-2 text-3xl font-semibold text-[var(--color-text)]">0→1</div>
              <div class="text-sm text-[var(--color-text-muted)]">Startup to scale experience</div>
            </div>
            <div>
              <div class="mb-2 text-3xl font-semibold text-[var(--color-text)]">Writing</div>
              <div class="text-sm text-[var(--color-text-muted)]">Sharing lessons learned</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Work Section -->
  {featuredProjects.length > 0 && (
    <section class="section-spacing border-t border-[var(--color-border)]/30">
      <div class="section-header reveal">
        <p class="section-eyebrow">Selected Work</p>
        <h2 class="section-title">Things I've built</h2>
        <p class="section-description">
          A selection of projects that showcase my approach to product and technology.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-animate-stagger>
        {featuredProjects.map((project) => (
          <a
            href={`/projects/${project.id}`}
            class="card-hover group block"
            data-animate-item
            data-astro-prefetch
          >
            {project.data.heroImage && (
              <div class="mb-4 aspect-video overflow-hidden rounded-xl bg-[var(--color-surface)]">
                <Picture
                  src={project.data.heroImage}
                  widths={[400, 800]}
                  sizes="(max-width: 768px) 100vw, 400px"
                  formats={['avif', 'webp', 'jpeg']}
                  alt={project.data.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>
            )}
            <h3 class="mb-2 text-lg font-semibold text-[var(--color-text)] transition-colors group-hover:text-[var(--color-accent)]">
              {project.data.title}
            </h3>
            <p class="mb-4 text-sm text-[var(--color-text-secondary)] line-clamp-2">
              {project.data.description}
            </p>
            {project.data.tags && (
              <div class="flex flex-wrap gap-2">
                {project.data.tags.slice(0, 3).map((tag: string) => (
                  <span class="pill text-xs">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>

      <div class="mt-12 text-center reveal">
        <a
          href="/projects"
          class="btn btn-secondary"
          data-astro-prefetch
        >
          View all work
        </a>
      </div>
    </section>
  )}

  <!-- Field Notes (Blog) Section -->
  <section class="section-spacing border-t border-[var(--color-border)]/30">
    <div class="section-header reveal">
      <p class="section-eyebrow">Field Notes</p>
      <h2 class="section-title">Recent writing</h2>
      <p class="section-description">
        Observations, frameworks, and lessons from building products.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-animate-stagger>
      {latestPosts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="card-hover group block"
          data-animate-item
          data-astro-prefetch
        >
          {post.data.heroImage && (
            <div class="mb-4 aspect-video overflow-hidden rounded-xl bg-[var(--color-surface)]">
              <Picture
                src={post.data.heroImage}
                widths={[400, 800]}
                sizes="(max-width: 768px) 100vw, 400px"
                formats={['avif', 'webp', 'jpeg']}
                alt={post.data.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
          )}
          <div class="mb-3 flex items-center gap-3 text-xs text-[var(--color-text-muted)]">
            <time datetime={post.data.date}>
              {new Date(post.data.date).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
              })}
            </time>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-[var(--color-text)] transition-colors group-hover:text-[var(--color-accent)]">
            {post.data.title}
          </h3>
          {post.data.description && (
            <p class="mb-4 text-sm text-[var(--color-text-secondary)] line-clamp-2">
              {post.data.description}
            </p>
          )}
          {post.data.tags && (
            <div class="flex flex-wrap gap-2">
              {post.data.tags.slice(0, 3).map((tag: string) => (
                <span class="pill text-xs">#{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>

    <div class="mt-12 text-center reveal">
      <a
        href="/blog"
        class="btn btn-secondary"
        data-astro-prefetch
      >
        Read all posts
      </a>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section
    id="newsletter-section"
    class="section-spacing border-t border-[var(--color-border)]/30"
  >
    <div class="reveal mx-auto max-w-2xl text-center">
      <div class="card-gradient relative overflow-hidden p-8 sm:p-12">
        <!-- Gradient overlay -->
        <div
          class="pointer-events-none absolute inset-0 opacity-50"
          style="background: radial-gradient(ellipse at top, rgba(139, 92, 246, 0.1) 0%, transparent 60%);"
        ></div>

        <div class="relative">
          <p class="section-eyebrow mb-4">Newsletter</p>
          <h2 class="display-heading mb-4 text-3xl text-[var(--color-text)] sm:text-4xl">
            Stochastic Musings
          </h2>
          <p class="mx-auto mb-8 max-w-md text-[var(--color-text-secondary)]">
            Notes on product intuition, engineering systems, and signals from the AI landscape.
            Exploring the messy reality of how intelligence meets execution.
          </p>

          <div class="flex flex-col items-center gap-4">
            <a
              href="https://stochasticmusings.substack.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary"
            >
              Subscribe for free
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
            <p class="text-sm text-[var(--color-text-muted)]">
              Join the journey · No spam, ever.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Line clamp utility */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
