---



import BlogHeader from '../components/BlogHeader.astro';
import Tags from '../components/Tags.astro';
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;
const readingTime = frontmatter.readingTime || 5;
---

<Layout title={frontmatter.title}>
  <article class="mx-auto max-w-3xl pt-4 md:pt-8">
    <BlogHeader
      title={frontmatter.title}
      subtitle={frontmatter.subtitle}
      date={new Date(frontmatter.date)}
      heroImage={frontmatter.heroImage}
      heroConfig={frontmatter.heroConfig}
      readingTime={readingTime}
    />

    {
      frontmatter.tags && (
        <div class="mt-6 mb-10">
          <Tags tags={frontmatter.tags} />
        </div>
      )
    }

    <!-- Article Content -->
    <div class="prose-editorial">
      <slot />
    </div>

    <!-- Article Footer -->
    <footer class="mt-20 border-t border-[var(--color-border)]/30 pt-12">
      <div class="flex flex-col gap-8 sm:flex-row sm:items-center sm:justify-between">
        <a
          href="/blog"
          class="group inline-flex items-center gap-2 text-sm font-medium uppercase tracking-[0.15em] text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-primary)]"
        >
          <svg class="h-4 w-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Field Notes
        </a>

        <!-- Share Section -->
        <div class="flex items-center gap-4">
          <span class="text-xs uppercase tracking-[0.15em] text-[var(--color-text-muted)]">Share</span>
          <div class="flex gap-3">
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(frontmatter.title)}&url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-9 w-9 items-center justify-center rounded-full border border-[var(--color-border)] text-[var(--color-text-muted)] transition-all hover:border-[var(--color-primary)]/50 hover:text-[var(--color-primary)]"
              aria-label="Share on Twitter"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-9 w-9 items-center justify-center rounded-full border border-[var(--color-border)] text-[var(--color-text-muted)] transition-all hover:border-[var(--color-primary)]/50 hover:text-[var(--color-primary)]"
              aria-label="Share on LinkedIn"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </footer>
  </article>
</Layout>

<style>
  /* Editorial prose styling - optimized for reading */
  .prose-editorial {
    color: var(--color-text-secondary-dark);
    font-size: 1.125rem;
    line-height: 1.8;
  }

  .prose-editorial :global(> * + *) {
    margin-top: 1.5em;
  }

  /* Headings */
  .prose-editorial :global(h1),
  .prose-editorial :global(h2),
  .prose-editorial :global(h3),
  .prose-editorial :global(h4) {
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--color-text-dark);
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    line-height: 1.3;
  }

  .prose-editorial :global(h1) { font-size: 2.25rem; }
  .prose-editorial :global(h2) { font-size: 1.75rem; }
  .prose-editorial :global(h3) { font-size: 1.375rem; }
  .prose-editorial :global(h4) { font-size: 1.125rem; }

  /* Links */
  .prose-editorial :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: rgba(139, 92, 246, 0.3);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.2s;
  }

  .prose-editorial :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  /* Strong and emphasis */
  .prose-editorial :global(strong) {
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .prose-editorial :global(em) {
    font-style: italic;
  }

  /* Blockquotes */
  .prose-editorial :global(blockquote) {
    position: relative;
    margin: 2rem 0;
    border-left: 2px solid var(--color-accent);
    background: var(--color-surface-dark);
    padding: 1.5rem;
    border-radius: 0 0.75rem 0.75rem 0;
    font-style: italic;
  }

  .prose-editorial :global(blockquote p) {
    color: var(--color-text-dark);
    margin: 0;
  }

  /* Code */
  .prose-editorial :global(code) {
    background: var(--color-surface-dark);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: var(--font-mono, monospace);
    color: var(--color-coral);
  }

  .prose-editorial :global(pre) {
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-surface-dark);
    border-radius: 0.75rem;
    overflow-x: auto;
  }

  .prose-editorial :global(pre code) {
    background: transparent;
    padding: 0;
    color: var(--color-text-secondary-dark);
  }

  /* Lists */
  .prose-editorial :global(ul),
  .prose-editorial :global(ol) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .prose-editorial :global(ul) { list-style-type: disc; }
  .prose-editorial :global(ol) { list-style-type: decimal; }

  .prose-editorial :global(li) {
    margin: 0.5rem 0;
  }

  .prose-editorial :global(li::marker) {
    color: var(--color-accent);
  }

  /* Images */
  .prose-editorial :global(img) {
    margin: 2rem 0;
    border-radius: 0.75rem;
  }

  /* Horizontal rule */
  .prose-editorial :global(hr) {
    margin: 3rem 0;
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Embedded content (YouTube, etc.) */
  .prose-editorial :global(iframe) {
    margin: 2rem 0;
    aspect-ratio: 16 / 9;
    width: 100%;
    border-radius: 0.75rem;
  }

  /* Light mode overrides */
  :global(html.light) .prose-editorial {
    color: var(--color-text-secondary-light);
  }

  :global(html.light) .prose-editorial :global(h1),
  :global(html.light) .prose-editorial :global(h2),
  :global(html.light) .prose-editorial :global(h3),
  :global(html.light) .prose-editorial :global(h4),
  :global(html.light) .prose-editorial :global(strong) {
    color: var(--color-text-light);
  }

  :global(html.light) .prose-editorial :global(a) {
    color: var(--color-primary-light);
  }

  :global(html.light) .prose-editorial :global(blockquote) {
    border-color: var(--color-primary-light);
    background: var(--color-surface-light);
  }

  :global(html.light) .prose-editorial :global(blockquote p) {
    color: var(--color-text-light);
  }

  :global(html.light) .prose-editorial :global(code) {
    background: var(--color-surface-light);
    color: var(--color-primary-light);
  }

  :global(html.light) .prose-editorial :global(pre) {
    background: var(--color-surface-light);
  }

  :global(html.light) .prose-editorial :global(li::marker) {
    color: var(--color-primary-light);
  }
</style>
