---
import { getImage } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import Footer from '../components/Footer.astro';
import Navigation from '../components/Navigation.astro';
import PostHog from '../components/posthog.astro';
import ScriptOptimizer from '../components/ScriptOptimizer.astro';
import avatar from '../images/avatar.jpg';
import '@fontsource/playfair-display';
import '@fontsource/playfair-display/400-italic.css';
import '@fontsource/roboto-slab';
import '@fontsource/plus-jakarta-sans';
import '../styles/globals.css';

interface Props {
  title: string;
  description?: string;
  analytics?: boolean;
  substack?: boolean;
  socialEmbed?: boolean;
}

const {
  title,
  description = 'Tech, AI & data products, and the stories picked up along the way',
  analytics = false,
  substack = false,
  socialEmbed = false,
} = Astro.props;

// Generate optimized image for preloading on homepage
const preloadImage = Astro.url.pathname === '/' ? await getImage({
  src: avatar,
  width: 128,
  format: 'webp'
}) : null;

const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Work' },
  { href: '/about', label: 'About' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#0a0d14" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafbfc" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Theme initialization (dark mode default, prevents FOUC) -->
    <script is:inline>
      (() => {
        function getTheme() {
          // Check localStorage first
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          // Default to dark mode (Editorial Noir)
          return 'dark';
        }

        function applyTheme() {
          const theme = getTheme();
          const html = document.documentElement;

          // Remove both classes first
          html.classList.remove('light', 'dark');

          // Add the appropriate class (we use 'light' class for light mode,
          // default/no class or 'dark' class for dark mode)
          if (theme === 'light') {
            html.classList.add('light');
          }
          // Dark is default, no class needed but we add it for consistency
        }

        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <!-- Critical inline styles -->
    <style is:inline>
      :root {
        color-scheme: dark light;
      }
      body {
        margin: 0;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      img {
        max-width: 100%;
        height: auto;
      }
      /* Prevent FOUC */
      html:not(.light) body {
        background: #0a0d14;
        color: #f0f2f7;
      }
      html.light body {
        background: #fafbfc;
        color: #111827;
      }
    </style>

    <!-- Preload profile image on homepage -->
    {preloadImage && (
      <link
        rel="preload"
        fetchpriority="high"
        as="image"
        type="image/webp"
        href={preloadImage.src}
      />
    )}

    <ScriptOptimizer analytics={analytics} substack={substack} socialEmbed={socialEmbed} />
    <PostHog />
    <ClientRouter />
  </head>

  <body class="min-h-screen bg-[var(--color-bg-dark)] font-sans text-[var(--color-text-dark)] antialiased transition-colors duration-300">
    <!-- Ambient glow effect -->
    <div
      class="pointer-events-none fixed inset-0 z-0"
      aria-hidden="true"
    >
      <!-- Top glow -->
      <div
        class="absolute -top-1/2 left-1/4 h-[800px] w-[800px] rounded-full opacity-30 blur-[120px]"
        style="background: radial-gradient(circle, rgba(139, 92, 246, 0.15) 0%, transparent 70%);"
      ></div>
      <!-- Bottom right glow -->
      <div
        class="absolute -bottom-1/4 right-0 h-[600px] w-[600px] rounded-full opacity-20 blur-[100px]"
        style="background: radial-gradient(circle, rgba(251, 113, 133, 0.1) 0%, transparent 70%);"
      ></div>
    </div>

    <!-- Noise texture overlay -->
    <div
      class="pointer-events-none fixed inset-0 z-[100] opacity-[0.015] mix-blend-overlay"
      aria-hidden="true"
      style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"
    ></div>

    <Navigation navLinks={navLinks} />

    <!-- Main Content -->
    <main class="relative z-10">
      <div class="mx-auto max-w-6xl px-4 pt-24 pb-16 sm:px-6 lg:px-8">
        <slot />
      </div>
    </main>

    <Footer navLinks={navLinks} />

    <!-- Scripts -->
    <script>
      // Mobile menu toggle
      function setupMobileMenu() {
        const menuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIconOpen = document.getElementById('menu-icon-open');
        const menuIconClose = document.getElementById('menu-icon-close');

        if (menuToggle && mobileMenu && menuIconOpen && menuIconClose) {
          const newToggle = menuToggle.cloneNode(true) as HTMLElement;
          if (menuToggle.parentNode) {
            menuToggle.parentNode.replaceChild(newToggle, menuToggle);
          }

          newToggle.addEventListener('click', () => {
            const isOpen = !mobileMenu.classList.contains('hidden');
            mobileMenu.classList.toggle('hidden');

            const openIcon = newToggle.querySelector('#menu-icon-open');
            const closeIcon = newToggle.querySelector('#menu-icon-close');

            if (openIcon && closeIcon) {
              if (isOpen) {
                openIcon.classList.remove('hidden');
                closeIcon.classList.add('hidden');
              } else {
                openIcon.classList.add('hidden');
                closeIcon.classList.remove('hidden');
              }
            }
          });
        }
      }

      setupMobileMenu();
      document.addEventListener('astro:page-load', setupMobileMenu);
    </script>

    <script>
      // Theme toggle logic
      function setupThemeToggle() {
        const themeToggle = document.getElementById('theme-toggle');
        const darkIcon = document.getElementById('theme-icon-dark');
        const lightIcon = document.getElementById('theme-icon-light');

        function updateIcons() {
          const isLight = document.documentElement.classList.contains('light');
          if (darkIcon && lightIcon) {
            if (isLight) {
              darkIcon.classList.add('hidden');
              lightIcon.classList.remove('hidden');
            } else {
              darkIcon.classList.remove('hidden');
              lightIcon.classList.add('hidden');
            }
          }
        }

        // Initial icon state
        updateIcons();

        if (themeToggle) {
          const newToggle = themeToggle.cloneNode(true) as HTMLElement;
          themeToggle.parentNode?.replaceChild(newToggle, themeToggle);

          newToggle.addEventListener('click', () => {
            const html = document.documentElement;
            const isCurrentlyLight = html.classList.contains('light');

            if (isCurrentlyLight) {
              html.classList.remove('light');
              localStorage.setItem('theme', 'dark');
            } else {
              html.classList.add('light');
              localStorage.setItem('theme', 'light');
            }

            // Update icons after toggle
            const updatedDarkIcon = newToggle.querySelector('#theme-icon-dark');
            const updatedLightIcon = newToggle.querySelector('#theme-icon-light');

            if (updatedDarkIcon && updatedLightIcon) {
              if (html.classList.contains('light')) {
                updatedDarkIcon.classList.add('hidden');
                updatedLightIcon.classList.remove('hidden');
              } else {
                updatedDarkIcon.classList.remove('hidden');
                updatedLightIcon.classList.add('hidden');
              }
            }
          });
        }
      }

      setupThemeToggle();
      document.addEventListener('astro:page-load', setupThemeToggle);
    </script>

    <script>
      // GSAP and ScrollTrigger setup
      import { animateFadeUp, animateStaggerGroup, cleanupAnimations, initGSAP, prefersReducedMotion } from '../scripts/gsap-setup';

      function setupAnimations() {
        initGSAP();

        // Animate reveal elements if not using reduced motion
        if (!prefersReducedMotion()) {
          // Fade up animations for elements with .gsap-fade-up class
          const fadeUpElements = document.querySelectorAll('.gsap-fade-up');
          if (fadeUpElements.length > 0) {
            animateFadeUp(fadeUpElements, { stagger: 0.1 });
          }

          // Stagger animations for card grids
          const cardGrids = document.querySelectorAll('[data-animate-stagger]');
          cardGrids.forEach((grid) => {
            animateStaggerGroup(grid, '[data-animate-item]', { stagger: 0.15 });
          });
        }
      }

      // Initial load
      setupAnimations();

      // View Transitions
      document.addEventListener('astro:page-load', () => {
        cleanupAnimations();
        setupAnimations();
      });

      // Cleanup on navigation
      document.addEventListener('astro:before-swap', cleanupAnimations);
    </script>

    <script>
      // Scroll reveal fallback for non-GSAP elements
      function setupScrollReveal() {
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('reveal-visible');
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        document.querySelectorAll('.reveal').forEach(el => {
          observer.observe(el);
        });
      }

      setupScrollReveal();
      document.addEventListener('astro:page-load', setupScrollReveal);
    </script>
  </body>
</html>

<style is:global>
  /* Nav backdrop - dark mode default */
  #nav-backdrop {
    background: linear-gradient(180deg, rgba(10, 13, 20, 0.95) 0%, rgba(10, 13, 20, 0.8) 100%);
  }

  /* Light mode body overrides */
  html.light body {
    background: var(--color-bg-light);
    color: var(--color-text-light);
  }

  /* Light mode nav */
  html.light #main-nav {
    border-color: var(--color-border-light);
  }

  html.light #nav-backdrop {
    background: linear-gradient(180deg, rgba(250, 251, 252, 0.95) 0%, rgba(250, 251, 252, 0.8) 100%);
  }

  html.light #main-nav a {
    color: var(--color-muted-light);
  }

  html.light #main-nav a:hover {
    color: var(--color-text-light);
  }

  html.light #main-nav a[href="/"] {
    color: var(--color-text-light);
  }

  html.light #main-nav a[href="/"]:hover {
    color: var(--color-primary-light);
  }

  html.light #theme-toggle,
  html.light #menu-toggle {
    border-color: var(--color-border-light);
    color: var(--color-muted-light);
  }

  html.light #theme-toggle:hover,
  html.light #menu-toggle:hover {
    border-color: var(--color-primary-light);
    color: var(--color-primary-light);
  }

  /* Light mode ambient glow - more subtle */
  html.light .pointer-events-none.fixed.inset-0.z-0 > div {
    opacity: 0.1 !important;
  }

  /* Light mode footer */
  html.light footer {
    border-color: var(--color-border-light);
  }

  html.light footer p,
  html.light footer a {
    color: var(--color-text-secondary-light);
  }

  html.light footer a:hover {
    color: var(--color-primary-light);
  }

  html.light footer .text-xs.uppercase {
    color: var(--color-muted-light);
  }
</style>
