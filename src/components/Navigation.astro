---
interface NavLink {
  href: string;
  label: string;
}

interface Props {
  navLinks: NavLink[];
}

const { navLinks } = Astro.props;
---

<nav
  id="main-nav"
  class="fixed left-0 right-0 top-0 z-50 border-b border-[var(--color-border-dark)]/50 transition-all duration-300"
>
  <div
    id="nav-backdrop"
    class="absolute inset-0 backdrop-blur-xl"
  ></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a
        href="/"
        class="group relative z-10 flex items-center gap-2 text-lg font-semibold tracking-tight text-[var(--color-text-dark)] transition-colors"
        data-astro-prefetch
      >
        <span class="transition-colors group-hover:text-[var(--color-accent)]">Soumyo Dey</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden items-center gap-8 md:flex">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="relative py-1 text-sm font-medium uppercase tracking-[0.15em] text-[var(--color-muted-dark)] transition-colors hover:text-[var(--color-text-dark)]"
            data-astro-prefetch
          >
            <span class="relative">
              {link.label}
              <span class="absolute -bottom-1 left-0 h-0.5 w-0 bg-[var(--color-accent)] transition-all duration-300 group-hover:w-full"></span>
            </span>
          </a>
        ))}
      </div>

      <!-- Right side controls -->
      <div class="flex items-center gap-3">
        <!-- Theme Toggle -->
        <button
          type="button"
          id="theme-toggle"
          aria-label="Toggle theme"
          class="relative z-10 flex h-10 w-10 items-center justify-center rounded-full border border-[var(--color-border-dark)] text-[var(--color-muted-dark)] transition-all hover:border-[var(--color-accent)]/50 hover:text-[var(--color-accent)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)]"
        >
          <!-- Moon icon (shown in dark mode, click to go light) -->
          <svg
            id="theme-icon-dark"
            aria-hidden="true"
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
            ></path>
          </svg>
          <!-- Sun icon (shown in light mode, click to go dark) -->
          <svg
            id="theme-icon-light"
            aria-hidden="true"
            class="hidden h-5 w-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
            ></path>
          </svg>
        </button>

        <!-- Mobile Menu Toggle -->
        <button
          type="button"
          id="menu-toggle"
          aria-label="Toggle navigation menu"
          class="relative z-10 flex h-10 w-10 items-center justify-center rounded-full border border-[var(--color-border-dark)] text-[var(--color-text-dark)] transition-all hover:border-[var(--color-accent)]/50 hover:text-[var(--color-accent)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] md:hidden"
        >
          <svg
            id="menu-icon-open"
            aria-hidden="true"
            class="h-5 w-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M4 6h16M4 12h16M4 18h16"
            ></path>
          </svg>
          <svg
            id="menu-icon-close"
            aria-hidden="true"
            class="hidden h-5 w-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M6 18L18 6M6 6l12 12"
            ></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="fixed left-0 right-0 top-16 z-[60] hidden border-t border-[var(--color-border-dark)]/50 bg-[var(--color-bg-dark)]/95 backdrop-blur-xl md:hidden"
  >
    <div
      class="px-4 py-6"
    >
      <div class="flex flex-col space-y-4">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-base font-medium uppercase tracking-[0.15em] text-[var(--color-muted-dark)] transition-colors hover:text-[var(--color-accent)]"
            data-astro-prefetch
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>
