---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import { formatCardDate } from "../utils/content";
import Tags from "./Tags.astro";

interface Props {
	href: string;
	title: string;
	description?: string;
	date: string;
	tags?: string[];
	heroImage?: ImageMetadata;
	showDivider?: boolean;
	animate?: boolean;
}

const {
	href,
	title,
	description,
	date,
	tags = [],
	heroImage,
	showDivider = true,
	animate = false,
} = Astro.props;
---

<article
	class:list={[
		"content-list-item group relative",
		showDivider && "content-list-item-divided",
	]}
	{...(animate ? { "data-animate-item": true } : {})}
>
	<div class="content-list-item-layout">
		<div class="content-list-item-content">
			<p class="content-list-item-meta">
				{formatCardDate(date, "long")}
			</p>
			<h2 class="content-list-item-title">
				<a href={href} data-astro-prefetch>
					<span class="absolute inset-0" aria-hidden="true" />
					{title}
				</a>
			</h2>
			{
				description && (
					<p class="content-list-item-description">{description}</p>
				)
			}
			{
				tags.length > 0 && (
					<div class="content-list-item-tags">
						<Tags tags={tags} />
					</div>
				)
			}
		</div>

		{
			heroImage && (
				<div class="content-list-item-thumb">
					<Picture
						src={heroImage}
						alt=""
						widths={[160, 320]}
						sizes="(max-width: 768px) 0px, 160px"
						formats={["avif", "webp", "jpeg"]}
						class="content-list-item-image"
					/>
				</div>
			)
		}
	</div>
</article>