---



import { format } from 'date-fns';
import Tags from './Tags.astro';

interface Props {
  url: string;
  title: string;
  description: string;
  date?: string;
  tags: string[];
}

const { url, title, description, date, tags } = Astro.props;
---

<article
  class="group relative overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
>
  <div>
    {
      date && (
        <div class="mb-3 flex items-center justify-between">
          <time datetime={date} class="text-sm font-medium text-[var(--color-text-muted)]">
            {format(new Date(date), 'MMMM d, yyyy')}
          </time>
        </div>
      )
    }
    <h2 class="mb-3 text-2xl font-bold font-serif text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors">
      <a href={url}>
        {title}
      </a>
    </h2>
    <p class="mb-4 leading-relaxed text-[var(--color-text-secondary)]">
      {description}
    </p>
    <Tags tags={tags} />
  </div>
</article>
