---
interface Props {
	label: string;
	overlay?: boolean;
	href?: string;
}

const { label, overlay = false, href } = Astro.props;
const Tag = href ? "a" : "span";
---

<Tag
	class:list={[
		href ? "content-card-details" : "content-card-cta",
		overlay && "content-card-cta--overlay",
	]}
	{...(href && { href, "data-astro-prefetch": true })}
>
	<span>{label}</span>
	<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
		<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
	</svg>
</Tag>