---
import type { StackedProjectProps } from "../utils/content";
import { formatCardMeta } from "../utils/content";
import CardCta from "./CardCta.astro";
import ContentCardImage from "./ContentCardImage.astro";
import Tags from "./Tags.astro";

interface Props extends StackedProjectProps {
	animate?: boolean;
}

const {
	href,
	title,
	description,
	date,
	tags = [],
	heroImage,
	github,
	demo,
	animate = false,
} = Astro.props;

const meta = formatCardMeta("project", date);
---

<article
	class="content-card content-card--stacked group relative flex h-full flex-col"
	{...(animate && { "data-animate-item": true })}
>
	{
		heroImage && (
			<div class="content-card-media content-card-media--stacked">
				<ContentCardImage
					src={heroImage}
					alt={title}
					widths={[400, 800, 1200]}
					sizes="(max-width: 768px) 100vw, 400px"
				/>
			</div>
		)
	}
	<div class="content-card-body flex flex-1 flex-col">
		{meta && <p class="content-card-meta">{meta}</p>}
		<h2 class="content-card-title text-xl font-semibold tracking-tight">{title}</h2>
		{description && <p class="content-card-description">{description}</p>}
		<div class="content-card-footer mt-auto">
			{
				tags.length > 0 && (
					<div class="content-card-tags">
						<Tags tags={tags} hashPrefix={false} limit={3} />
					</div>
				)
			}
		</div>
		<div class="content-card-actions">
			{
				github && (
					<a
						href={github}
						class="content-card-action"
						target="_blank"
						rel="noopener noreferrer"
					>
						<svg
							class="h-4 w-4"
							fill="currentColor"
							viewBox="0 0 24 24"
							aria-hidden="true"
						>
							<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
						</svg>
						Code
					</a>
				)
			}
			{
				demo && (
					<a
						href={demo}
						class="content-card-action"
						target="_blank"
						rel="noopener noreferrer"
					>
						<svg
							class="h-4 w-4"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							aria-hidden="true"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
							/>
						</svg>
						Demo
					</a>
				)
			}
			<CardCta label="View details" href={href} />
		</div>
	</div>
</article>